{
  "name": "moneymap-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "prisma generate && next build",
    "start": "next start -p 3001",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:ingest-internet-offers": "npx tsx --env-file=.env scripts/ingest_internet_offers.mts",
    "db:seed-spend-categories": "npx tsx --env-file=.env scripts/seed_spend_categories.mts",
    "categorise:transactions": "npx tsx --env-file=.env scripts/backfill_transaction_categories.mts",
    "categorise:secondary-mine": "npx tsx --env-file=.env scripts/mine_secondary_patterns.mts",
    "categorise:secondary-seed": "npx tsx --env-file=.env scripts/seed_secondary_l3_rules.mts",
    "categorise:merchant-map": "npx tsx --env-file=.env scripts/build_merchant_map.mts",
    "categorise:train-model": "npx tsx --env-file=.env scripts/train_category_model.mts",
    "categorise:propose-rules": "npx tsx --env-file=.env scripts/propose_secondary_rules.mts",
    "income:sync": "npx tsx --env-file=.env scripts/sync_basiq_income.mts",
    "test:taxonomy-categoriser": "npx tsx scripts/test_taxonomy_categoriser.mts",
    "test:secondary-patterns": "npx tsx scripts/test_secondary_patterns.mts",
    "test:rescan-import": "npx tsx scripts/test_rescan_import_modules.mts",
    "detect:internet-bills": "npx tsx --env-file=.env scripts/run_internet_bill_detection.mts",
    "test:internet-bill-integration": "npx tsx --env-file=.env scripts/internet_bill_detection_integration_smoke.mts",
    "test:internet-savings-intake": "npx tsx scripts/test_internet_savings_intake_schema.mts",
    "test:internet-savings-integration": "npx tsx --env-file=.env scripts/internet_savings_intake_smoke.mts",
    "test:internet-capability-provider": "npx tsx scripts/test_hfc_capability_provider.mts",
    "test:internet-capability-integration": "npx tsx --env-file=.env scripts/internet_capability_integration_smoke.mts",
    "test:isolation": "npx tsx --env-file=.env scripts/isolation-smoke.mts",
    "test:internet-bill-detector": "npx tsx scripts/test_internet_bill_detector.mts"
  },
  "dependencies": {
    "@basiq/basiq-javascript-sdk": "^1.0.3",
    "@prisma/client": "^6.11.1",
    "bcryptjs": "^3.0.2",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "next": "^15.3.5",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.16.5",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "prisma": "^6.11.1",
    "tsx": "^4.23.0",
    "typescript": "^5.8.3"
  }
}
