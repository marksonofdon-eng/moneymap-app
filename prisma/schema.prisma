generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                               String    @id @default(cuid())
  email                            String    @unique
  passwordHash                     String    @map("password_hash")
  name                             String?
  basiqUserId                      String?   @unique @map("basiq_user_id") @db.VarChar(64)
  financialHealthContactRequested  Boolean   @default(false) @map("financial_health_contact_requested")
  financialHealthContactAt         DateTime? @map("financial_health_contact_at") @db.Timestamptz(6)
  createdAt                        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                        DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  sessions              Session[]
  accounts              BasiqAccount[]
  transactions          BasiqTransaction[]
  detectedBills         DetectedBill[]
  billEvidence          BillEvidence[]
  addresses             UserAddress[]
  needProfiles          UserNeedProfile[]
  capabilityAssessments AddressCapabilityAssessment[]
  accessOptions         AddressAccessOption[]
  incomeReports         BasiqIncomeReport[]
  incomeSources         BasiqIncomeSource[]
  secondaryCategoryRules SecondaryCategoryRule[]
  categoryAssignmentEvents CategoryAssignmentEvent[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_sessions_user_id")
  @@index([expiresAt], map: "idx_sessions_expires_at")
  @@map("sessions")
}

/// Bank accounts owned by a MoneyMap user. basiqUserId is the external Basiq id only.
model BasiqAccount {
  accountId        String   @id @map("account_id") @db.VarChar(64)
  ownerUserId      String   @map("owner_user_id")
  basiqUserId      String   @map("basiq_user_id") @db.VarChar(64)
  name             String?
  type             String?  @db.VarChar(64)
  balance          Decimal? @db.Decimal(19, 4)
  availableBalance Decimal? @map("available_balance") @db.Decimal(19, 4)
  currency         String   @default("AUD") @db.Char(3)
  ingestedAt       DateTime @default(now()) @map("ingested_at") @db.Timestamptz(6)
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  owner        User               @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  transactions BasiqTransaction[]

  @@index([ownerUserId], map: "idx_basiq_accounts_owner_user_id")
  @@index([ownerUserId, accountId], map: "idx_basiq_accounts_owner_account")
  @@index([basiqUserId], map: "idx_basiq_accounts_basiq_user_id")
  @@map("basiq_accounts")
}

/// Transactions denormalize ownerUserId for fast tenant filters + RLS.
model BasiqTransaction {
  transactionId          String          @id @map("transaction_id") @db.VarChar(64)
  ownerUserId            String          @map("owner_user_id")
  accountId              String          @map("account_id") @db.VarChar(64)
  amount                 Decimal         @db.Decimal(19, 4)
  direction              String          @db.VarChar(16)
  postDate               DateTime?       @map("post_date") @db.Timestamptz(6)
  status                 String?         @db.VarChar(32)
  rawPayload             Json            @map("raw_payload")
  /// EXPENSE (debit spend) | INCOME / TRANSFER / OTHER (credits).
  flowType               TransactionFlow? @map("flow_type")
  /// Basiq transaction class string (payment, transfer, direct-credit, …).
  basiqTxClass           String?         @map("basiq_tx_class") @db.VarChar(64)
  /// Optional link to a Basiq Income API source series.
  incomeSourceId         String?         @map("income_source_id")
  /// Denormalized Basiq L4 from rawPayload only — never invented by enrichment.
  subclassCode           String?         @map("subclass_code") @db.VarChar(16)
  /// Denormalized Basiq L3 from rawPayload only — never invented by enrichment.
  groupCode              Int?            @map("group_code")
  /// MoneyMap UI enrichment (not a Basiq field).
  parentCategory         String?         @map("parent_category") @db.VarChar(80)
  /// MoneyMap UI enrichment (not a Basiq field).
  expenseCategory        String?         @map("expense_category") @db.VarChar(120)
  categoryConfidence     Int?            @map("category_confidence")
  categorySource         CategorySource? @map("category_source")
  categoryMatcherVersion String?         @map("category_matcher_version") @db.VarChar(32)
  /// Secondary (or future user) rule id when categorySource is SECONDARY_PATTERN / USER_RULE.
  categoryRuleId         String?         @map("category_rule_id") @db.VarChar(40)
  categorisedAt          DateTime?       @map("categorised_at") @db.Timestamptz(6)
  ingestedAt             DateTime        @default(now()) @map("ingested_at") @db.Timestamptz(6)
  updatedAt              DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  owner         User              @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  account       BasiqAccount      @relation(fields: [accountId], references: [accountId], onUpdate: Cascade, onDelete: Restrict)
  spendCategory SpendCategory?    @relation(fields: [subclassCode], references: [subclassCode], onDelete: SetNull, onUpdate: Cascade)
  incomeSource  BasiqIncomeSource? @relation(fields: [incomeSourceId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  categoryRule  SecondaryCategoryRule? @relation(fields: [categoryRuleId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  billEvidence  BillEvidence?
  assignmentEvents CategoryAssignmentEvent[]

  @@index([ownerUserId, postDate(sort: Desc)], map: "idx_basiq_transactions_owner_post_date")
  @@index([ownerUserId, accountId, postDate(sort: Desc)], map: "idx_basiq_transactions_owner_account_post_date")
  @@index([accountId], map: "idx_basiq_transactions_account_id")
  @@index([status], map: "idx_basiq_transactions_status")
  @@index([ownerUserId, groupCode, postDate(sort: Desc)], map: "idx_basiq_transactions_owner_group_post_date")
  @@index([ownerUserId, subclassCode], map: "idx_basiq_transactions_owner_subclass")
  @@index([ownerUserId, parentCategory], map: "idx_basiq_transactions_owner_parent_category")
  @@index([ownerUserId, expenseCategory], map: "idx_basiq_transactions_owner_expense_category")
  @@index([ownerUserId, categorySource], map: "idx_basiq_transactions_owner_category_source")
  @@index([ownerUserId, flowType], map: "idx_basiq_transactions_owner_flow_type")
  @@index([ownerUserId, basiqTxClass], map: "idx_basiq_transactions_owner_basiq_tx_class")
  @@index([incomeSourceId], map: "idx_basiq_transactions_income_source")
  @@index([categoryRuleId], map: "idx_basiq_transactions_category_rule")
  @@index([ownerUserId, categoryRuleId], map: "idx_basiq_transactions_owner_category_rule")
  @@index([categorySource, categoryRuleId], map: "idx_basiq_transactions_source_rule")
  @@map("basiq_transactions")
}

/// Basiq L3/L4 → end-user Parent/Expense mapping (from End_User_Expense_Mapping.xlsx).
model SpendCategory {
  /// Basiq L3 code.
  groupCode       Int    @map("group_code")
  /// Basiq L3 group name.
  groupTitle      String @map("group_title") @db.VarChar(200)
  /// Basiq L4 class code (stringified).
  subclassCode    String @id @map("subclass_code") @db.VarChar(16)
  /// Basiq L4 class name.
  subclassTitle   String @map("subclass_title") @db.VarChar(200)
  /// Display label: "Parent · Expense".
  fullLabel       String @map("full_label") @db.VarChar(240)
  parentCategory  String @map("parent_category") @db.VarChar(80)
  expenseCategory String @map("expense_category") @db.VarChar(120)

  transactions BasiqTransaction[]

  @@index([groupCode], map: "idx_spend_categories_group_code")
  @@index([parentCategory], map: "idx_spend_categories_parent_category")
  @@index([expenseCategory], map: "idx_spend_categories_expense_category")
  @@map("spend_categories")
}

enum CategorySource {
  BASIQ_ENRICH
  KEYWORD
  MANUAL
  UNMATCHED
  BASIQ_CLASS
  INCOME_API
  SECONDARY_PATTERN
  /// Confidence-gated supervised / embedding secondary model.
  MODEL
  /// Reserved for future per-user approved rules (third tier).
  USER_RULE

  @@map("category_source")
}

enum MerchantMapSource {
  LABELLED
  RULE
  MANUAL

  @@map("merchant_map_source")
}

/// Global merchant-token → Parent/Expense map (promoted into scr_ MERCHANT_TOKEN rules).
model MerchantCategoryMap {
  id              String            @id @default(cuid())
  merchantKey     String            @map("merchant_key") @db.VarChar(120)
  parentCategory  String            @map("parent_category") @db.VarChar(80)
  expenseCategory String            @map("expense_category") @db.VarChar(120)
  flowType        TransactionFlow   @default(EXPENSE) @map("flow_type")
  supportCount    Int               @default(0) @map("support_count")
  agreementPct    Int               @default(100) @map("agreement_pct")
  source          MerchantMapSource @default(LABELLED)
  matcherVersion  String            @default("merchant-map-v1") @map("matcher_version") @db.VarChar(32)
  ruleId          String?           @map("rule_id") @db.VarChar(40)
  createdBy       String            @default("system") @map("created_by") @db.VarChar(80)
  notes           String?           @db.VarChar(500)
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  rule SecondaryCategoryRule? @relation(fields: [ruleId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@unique([merchantKey], map: "uq_merchant_category_map_key")
  @@index([ruleId], map: "idx_merchant_category_map_rule")
  @@map("merchant_category_map")
}

enum SecondaryRuleStatus {
  CANDIDATE
  ACTIVE
  DISABLED
  REVOKED

  @@map("secondary_rule_status")
}

enum SecondaryPatternType {
  DESC_NORMALIZED
  BASIQ_L3
  MERCHANT_TOKEN

  @@map("secondary_pattern_type")
}

enum SecondaryOwnerScope {
  GLOBAL
  USER

  @@map("secondary_owner_scope")
}

/// Global (v1) secondary categorisation rule with stable audit id (scr_…).
model SecondaryCategoryRule {
  id               String               @id @db.VarChar(40)
  status           SecondaryRuleStatus  @default(CANDIDATE)
  patternType      SecondaryPatternType @map("pattern_type")
  patternValue     String               @map("pattern_value") @db.VarChar(240)
  matchSpec        Json                 @map("match_spec")
  parentCategory   String               @map("parent_category") @db.VarChar(80)
  expenseCategory  String               @map("expense_category") @db.VarChar(120)
  flowType         TransactionFlow      @default(EXPENSE) @map("flow_type")
  confidence       Int
  supportCount     Int                  @default(0) @map("support_count")
  ownerScope       SecondaryOwnerScope  @default(GLOBAL) @map("owner_scope")
  ownerUserId      String?              @map("owner_user_id")
  requiresApproval Boolean              @default(false) @map("requires_approval")
  matcherVersion   String               @default("secondary-v1") @map("matcher_version") @db.VarChar(32)
  createdBy        String               @map("created_by") @db.VarChar(80)
  notes            String?              @db.VarChar(500)
  createdAt        DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  activatedAt      DateTime?            @map("activated_at") @db.Timestamptz(6)
  disabledAt       DateTime?            @map("disabled_at") @db.Timestamptz(6)
  revokedAt        DateTime?            @map("revoked_at") @db.Timestamptz(6)
  updatedAt        DateTime             @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  owner        User?                      @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)
  transactions BasiqTransaction[]
  events       CategoryAssignmentEvent[]
  merchantMaps MerchantCategoryMap[]

  @@unique([patternType, patternValue, ownerScope, ownerUserId], map: "uq_secondary_rules_pattern_scope")
  @@index([status, ownerScope], map: "idx_secondary_rules_status_scope")
  @@index([ownerUserId], map: "idx_secondary_rules_owner")
  @@map("secondary_category_rules")
}

/// Append-only categorisation audit log.
model CategoryAssignmentEvent {
  id             String          @id @default(cuid())
  transactionId  String          @map("transaction_id") @db.VarChar(64)
  ownerUserId    String          @map("owner_user_id")
  ruleId         String?         @map("rule_id") @db.VarChar(40)
  categorySource CategorySource  @map("category_source")
  fromParent     String?         @map("from_parent") @db.VarChar(80)
  fromExpense    String?         @map("from_expense") @db.VarChar(120)
  fromSource     CategorySource? @map("from_source")
  toParent       String?         @map("to_parent") @db.VarChar(80)
  toExpense      String?         @map("to_expense") @db.VarChar(120)
  toSource       CategorySource  @map("to_source")
  toFlowType     TransactionFlow? @map("to_flow_type")
  matcherVersion String          @map("matcher_version") @db.VarChar(32)
  reason         String          @db.VarChar(240)
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)

  transaction BasiqTransaction      @relation(fields: [transactionId], references: [transactionId], onDelete: Cascade)
  owner       User                  @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  rule        SecondaryCategoryRule? @relation(fields: [ruleId], references: [id], onDelete: SetNull)

  @@index([transactionId, createdAt(sort: Desc)], map: "idx_category_events_tx")
  @@index([ownerUserId, createdAt(sort: Desc)], map: "idx_category_events_owner")
  @@index([ruleId], map: "idx_category_events_rule")
  @@map("category_assignment_events")
}

enum TransactionFlow {
  EXPENSE
  INCOME
  TRANSFER
  OTHER

  @@map("transaction_flow")
}

enum IncomeSourceKind {
  REGULAR
  IRREGULAR
  OTHER_CREDIT

  @@map("income_source_kind")
}

/// Snapshot of a Basiq Income API summary for a user.
model BasiqIncomeReport {
  id                  String    @id @db.VarChar(64)
  ownerUserId         String    @map("owner_user_id")
  basiqUserId         String    @map("basiq_user_id") @db.VarChar(64)
  fromMonth           String    @map("from_month") @db.VarChar(7)
  toMonth             String    @map("to_month") @db.VarChar(7)
  coverageDays        Int?      @map("coverage_days")
  generatedAt         DateTime? @map("generated_at") @db.Timestamptz(6)
  regularIncomeAvg    Decimal?  @map("regular_income_avg") @db.Decimal(19, 4)
  regularIncomeYtd    Decimal?  @map("regular_income_ytd") @db.Decimal(19, 4)
  regularIncomeYear   Decimal?  @map("regular_income_year") @db.Decimal(19, 4)
  irregularIncomeAvg  Decimal?  @map("irregular_income_avg") @db.Decimal(19, 4)
  summary             Json?
  rawPayload          Json      @map("raw_payload")
  syncedAt            DateTime  @default(now()) @map("synced_at") @db.Timestamptz(6)
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  owner   User               @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  sources BasiqIncomeSource[]

  @@index([ownerUserId, syncedAt(sort: Desc)], map: "idx_basiq_income_reports_owner")
  @@index([basiqUserId], map: "idx_basiq_income_reports_basiq_user")
  @@map("basiq_income_reports")
}

/// One regular / irregular / otherCredit series from a Basiq income report.
model BasiqIncomeSource {
  id                   String           @id @default(cuid())
  reportId             String           @map("report_id") @db.VarChar(64)
  ownerUserId          String           @map("owner_user_id")
  kind                 IncomeSourceKind
  source               String           @db.VarChar(240)
  frequency            String?          @db.VarChar(32)
  ageDays              Int?             @map("age_days")
  stability            Decimal?         @db.Decimal(6, 4)
  amountAvg            Decimal?         @map("amount_avg") @db.Decimal(19, 4)
  amountAvgMonthly     Decimal?         @map("amount_avg_monthly") @db.Decimal(19, 4)
  occurrenceCount      Int?             @map("occurrence_count")
  avgMonthlyOccurrence Decimal?         @map("avg_monthly_occurrence") @db.Decimal(12, 4)
  currentAmount        Decimal?         @map("current_amount") @db.Decimal(19, 4)
  currentDate          DateTime?        @map("current_date") @db.Timestamptz(6)
  nextDate             DateTime?        @map("next_date") @db.Timestamptz(6)
  otherCreditLabel     String?          @map("other_credit_label") @db.VarChar(120)
  parentCategory       String           @default("Income") @map("parent_category") @db.VarChar(80)
  incomeCategory       String           @map("income_category") @db.VarChar(120)
  rawPayload           Json             @map("raw_payload")
  createdAt            DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  report       BasiqIncomeReport  @relation(fields: [reportId], references: [id], onDelete: Cascade)
  owner        User               @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  transactions BasiqTransaction[]

  @@index([ownerUserId, kind], map: "idx_basiq_income_sources_owner_kind")
  @@index([reportId], map: "idx_basiq_income_sources_report")
  @@index([ownerUserId, incomeCategory], map: "idx_basiq_income_sources_owner_category")
  @@map("basiq_income_sources")
}

enum ExpenseCategory {
  INTERNET
  OTHER

  @@map("expense_category")
}

enum DetectedBillStatus {
  DETECTED
  CONFIRMED
  DISMISSED

  @@map("detected_bill_status")
}

enum BillingCadence {
  MONTHLY

  @@map("billing_cadence")
}

/// A recurring expense inferred from a user's bank transactions.
model DetectedBill {
  id                      String             @id @default(cuid())
  ownerUserId             String             @map("owner_user_id")
  category                ExpenseCategory    @default(INTERNET)
  /// Basiq L3 group when known (e.g. 580 = telecom).
  groupCode               Int?               @map("group_code")
  /// Basiq L4 class when known (e.g. 5801 = Wired Telecom / Internet).
  subclassCode            String?            @map("subclass_code") @db.VarChar(16)
  /// Stable detector grouping key; currently provider + source account.
  seriesKey               String             @map("series_key") @db.VarChar(160)
  providerKey             String             @map("provider_key") @db.VarChar(64)
  providerName            String             @map("provider_name") @db.VarChar(120)
  estimatedMonthlyCostAud Decimal            @map("estimated_monthly_cost_aud") @db.Decimal(12, 2)
  cadence                 BillingCadence     @default(MONTHLY)
  confidence              Int
  status                  DetectedBillStatus @default(DETECTED)
  occurrenceCount         Int                @map("occurrence_count")
  firstSeenAt             DateTime           @map("first_seen_at") @db.Timestamptz(6)
  lastSeenAt              DateTime           @map("last_seen_at") @db.Timestamptz(6)
  matcherVersion          String             @map("matcher_version") @db.VarChar(32)
  createdAt               DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  owner        User              @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  evidence     BillEvidence[]
  needProfiles UserNeedProfile[]

  @@unique([ownerUserId, category, seriesKey], map: "uq_detected_bills_owner_category_series")
  @@index([ownerUserId, category, status], map: "idx_detected_bills_owner_category_status")
  @@index([ownerUserId, groupCode, status], map: "idx_detected_bills_owner_group_status")
  @@index([ownerUserId, lastSeenAt(sort: Desc)], map: "idx_detected_bills_owner_last_seen")
  @@map("detected_bills")
}

/// Explainable transaction-level support for a detected recurring bill.
model BillEvidence {
  id                 String   @id @default(cuid())
  ownerUserId        String   @map("owner_user_id")
  detectedBillId     String   @map("detected_bill_id")
  transactionId      String   @unique @map("transaction_id") @db.VarChar(64)
  matchedProviderKey String   @map("matched_provider_key") @db.VarChar(64)
  matchedText        String   @map("matched_text") @db.Text
  matchScore         Int      @map("match_score")
  matchReasons       String[] @map("match_reasons")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  owner        User             @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  detectedBill DetectedBill     @relation(fields: [detectedBillId], references: [id], onDelete: Cascade)
  transaction  BasiqTransaction @relation(fields: [transactionId], references: [transactionId], onDelete: Cascade)

  @@index([ownerUserId, detectedBillId], map: "idx_bill_evidence_owner_bill")
  @@map("bill_evidence")
}

enum AustralianState {
  ACT
  NSW
  NT
  QLD
  SA
  TAS
  VIC
  WA

  @@map("australian_state")
}

/// Service address used for internet capability lookup.
model UserAddress {
  id          String          @id @default(cuid())
  ownerUserId String          @map("owner_user_id")
  line1       String          @db.VarChar(200)
  line2       String?         @db.VarChar(200)
  suburb      String          @db.VarChar(120)
  state       AustralianState
  postcode    String          @db.VarChar(4)
  country     String          @default("AU") @db.Char(2)
  lat         Decimal?        @db.Decimal(9, 6)
  lng         Decimal?        @db.Decimal(9, 6)
  createdAt   DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  owner                 User                          @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  needProfiles          UserNeedProfile[]
  capabilityAssessments AddressCapabilityAssessment[]

  @@unique([ownerUserId], map: "uq_user_addresses_owner")
  @@index([ownerUserId, postcode], map: "idx_user_addresses_owner_postcode")
  @@map("user_addresses")
}

/// Preferences and readiness for a category recommendation run.
model UserNeedProfile {
  id               String          @id @default(cuid())
  ownerUserId      String          @map("owner_user_id")
  category         ExpenseCategory @default(INTERNET)
  detectedBillId   String?         @map("detected_bill_id")
  serviceAddressId String?         @map("service_address_id")
  minDownloadMbps  Int             @map("min_download_mbps")
  allowWired       Boolean         @default(true) @map("allow_wired")
  allow5g          Boolean         @default(true) @map("allow_5g")
  allowStarlink    Boolean         @default(true) @map("allow_starlink")
  readyForAssess   Boolean         @default(false) @map("ready_for_assess")
  createdAt        DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  owner          User          @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  detectedBill   DetectedBill? @relation(fields: [detectedBillId], references: [id], onDelete: SetNull)
  serviceAddress UserAddress?  @relation(fields: [serviceAddressId], references: [id], onDelete: SetNull)

  @@unique([ownerUserId, category], map: "uq_user_need_profiles_owner_category")
  @@index([ownerUserId, readyForAssess], map: "idx_user_need_profiles_owner_ready")
  @@map("user_need_profiles")
}

enum CapabilityAssessmentStatus {
  PENDING
  READY
  FAILED

  @@map("capability_assessment_status")
}

enum InternetAccessFamily {
  NBN
  FIVE_G
  STARLINK

  @@map("internet_access_family")
}

/// A point-in-time serviceability lookup for one address.
model AddressCapabilityAssessment {
  id                 String                     @id @default(cuid())
  ownerUserId        String                     @map("owner_user_id")
  addressId          String                     @map("address_id")
  addressFingerprint String                     @map("address_fingerprint") @db.VarChar(64)
  provider           String                     @db.VarChar(64)
  status             CapabilityAssessmentStatus @default(PENDING)
  checkedAt          DateTime                   @map("checked_at") @db.Timestamptz(6)
  rawPayload         Json                       @map("raw_payload")
  failureReason      String?                    @map("failure_reason") @db.Text
  createdAt          DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime                   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  owner   User                  @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  address UserAddress           @relation(fields: [addressId], references: [id], onDelete: Cascade)
  options AddressAccessOption[]

  @@index([ownerUserId, addressId, checkedAt(sort: Desc)], map: "idx_capability_assessments_owner_address_checked")
  @@index([ownerUserId, status], map: "idx_capability_assessments_owner_status")
  @@map("address_capability_assessments")
}

/// One physical internet access path found by a capability assessment.
model AddressAccessOption {
  id                 String                  @id @default(cuid())
  ownerUserId        String                  @map("owner_user_id")
  assessmentId       String                  @map("assessment_id")
  accessFamily       InternetAccessFamily    @map("access_family")
  connectionType     InternetConnectionType? @map("connection_type")
  available          Boolean
  maxDownMbps        Int?                    @map("max_down_mbps")
  maxUpMbps          Int?                    @map("max_up_mbps")
  typicalEveningMbps Int?                    @map("typical_evening_mbps")
  confidence         Int
  notes              String?                 @db.Text
  createdAt          DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)

  owner      User                        @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  assessment AddressCapabilityAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([ownerUserId, accessFamily, available], map: "idx_access_options_owner_family_available")
  @@index([assessmentId], map: "idx_access_options_assessment")
  @@map("address_access_options")
}

enum InternetConnectionType {
  FTTP
  FTTN
  FTTC
  HFC
  FIXED_WIRELESS  @map("Fixed Wireless")
  FIVE_G_WIRELESS @map("5G Wireless")

  @@map("internet_connection_type")
}

enum InternetDataAllowance {
  Unlimited
  Capped

  @@map("internet_data_allowance")
}

enum InternetOfferStatus {
  Active
  Expired
  Draft
  Hold

  @@map("internet_offer_status")
}

/// Retail NBN / wireless market offers for bill-comparison.
model InternetMarketOffer {
  id                                  Int                    @id @default(autoincrement())
  providerName                        String                 @map("provider_name")
  planName                            String                 @map("plan_name")
  connectionType                      InternetConnectionType @map("connection_type")
  maxDownloadSpeed                    Int                    @map("max_download_speed")
  typicalEveningSpeed                 Int                    @map("typical_evening_speed")
  uploadSpeed                         Int                    @map("upload_speed")
  ongoingMonthlyCost                  Decimal                @map("ongoing_monthly_cost") @db.Decimal(10, 2)
  promoMonthlyCost                    Decimal                @map("promo_monthly_cost") @db.Decimal(10, 2)
  promoDurationMonths                 Int                    @default(0) @map("promo_duration_months")
  modemCost                           Decimal                @default(0) @map("modem_cost") @db.Decimal(10, 2)
  setupFee                            Decimal                @default(0) @map("setup_fee") @db.Decimal(10, 2)
  exitFee                             Decimal                @default(0) @map("exit_fee") @db.Decimal(10, 2)
  dataAllowance                       InternetDataAllowance  @map("data_allowance")
  contractTermMonths                  Int                    @map("contract_term_months")
  bundledPerksNotes                   String?                @map("bundled_perks_notes") @db.Text
  targetPostcode                      String                 @default("ALL") @map("target_postcode") @db.VarChar(16)
  networkOwner                        String                 @default("NBN") @map("network_owner") @db.VarChar(64)
  deepLinkUrl                         String?                @map("deep_link_url") @db.Text
  /// First-year cash outlay: promo window + residual months + modem + setup.
  calculatedFirstYearTotalCostAud     Decimal                @map("calculated_first_year_total_cost_aud") @db.Decimal(12, 2)
  /// First-year total amortized over 12 months.
  calculatedTrueAverageMonthlyCostAud Decimal                @map("calculated_true_average_monthly_cost_aud") @db.Decimal(12, 4)
  /// True average monthly cost per typical evening Mbps.
  calculatedCostPerMbpsMetric         Decimal                @map("calculated_cost_per_mbps_metric") @db.Decimal(12, 6)
  /// Admin flag: include in Top 5 shortlist.
  top5                                Boolean                @default(false) @map("top5")
  /// Admin flag: record has a data/review issue.
  issue                               Boolean                @default(false) @map("issue")
  /// Lifecycle status for admin review (writable in admin UI).
  status                              InternetOfferStatus    @default(Draft)
  /// Set only when status changes — not when market fields change.
  statusUpdatedAt                     DateTime               @default(now()) @map("status_updated_at") @db.Timestamptz(6)
  /// Plan/market last updated — bumps on market-field writes only (not status/flags).
  lastUpdated                         DateTime               @default(now()) @map("last_updated") @db.Timestamptz(6)

  @@index([providerName], map: "idx_internet_market_offers_provider_name")
  @@index([connectionType], map: "idx_internet_market_offers_connection_type")
  @@index([maxDownloadSpeed], map: "idx_internet_market_offers_max_download_speed")
  @@index([typicalEveningSpeed], map: "idx_internet_market_offers_typical_evening_speed")
  @@index([ongoingMonthlyCost], map: "idx_internet_market_offers_ongoing_monthly_cost")
  @@index([targetPostcode], map: "idx_internet_market_offers_target_postcode")
  @@index([networkOwner], map: "idx_internet_market_offers_network_owner")
  @@index([lastUpdated], map: "idx_internet_market_offers_last_updated")
  @@index([statusUpdatedAt], map: "idx_internet_market_offers_status_updated_at")
  @@index([calculatedTrueAverageMonthlyCostAud], map: "idx_internet_market_offers_true_avg_monthly_asc")
  @@index([status], map: "idx_internet_market_offers_status")
  @@index([top5], map: "idx_internet_market_offers_top5")
  @@index([issue], map: "idx_internet_market_offers_issue")
  @@map("internet_market_offers")
}
